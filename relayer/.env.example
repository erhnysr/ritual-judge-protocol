# Copy to .env and fill in. Never commit .env.

# ===== Arc testnet (chain 5042002) — Coliseum + AIJudgePanel live here =====
ARC_RPC_URL=https://rpc.testnet.arc.network
# Signer that is authorized as a relayer on AIJudgePanel (setRelayer / constructor).
ARC_PRIVATE_KEY=0x...

# Coliseum ArenaFactory on Arc (source of SubmissionCreated events).
ARENA_FACTORY_ADDRESS=0x13a38e7C2bA5AFA76a1AC21Eaef9f4DEA293FEBe
# AIJudgePanel on Arc (deploy with script/DeployAIJudgePanel.s.sol).
AI_JUDGE_PANEL_ADDRESS=

# Block to start backfilling Coliseum submissions from (0 = from arena creation via factory).
START_BLOCK=0

# ===== Ritual chain (chain 1979) — inference runs here =====
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
# Signer funded in RitualWallet to pay LLM precompile fees (see hermes-ritual-bridge).
RITUAL_PRIVATE_KEY=0x...
# Deployed HermesRitualLLM on Ritual testnet.
HERMES_RITUAL_LLM_ADDRESS=0x076d193E55C526ae709c529EA952847eB3eb2441

# Optional: comma-separated executor addresses to force (must be >=3 distinct).
# If unset, the relayer discovers them from the TEEServiceRegistry.
EXECUTOR_ADDRESSES=

# Degraded fallback for when Ritual has < 3 valid LLM executors registered:
# set to true to cycle the available executor(s) to fill the panel. This is NOT
# genuine multi-model consensus — use only for testing / degraded liveness.
ALLOW_EXECUTOR_REUSE=false

# Optional: HTTP gateway used to resolve ipfs:// contentRefs.
IPFS_GATEWAY=https://ipfs.io/ipfs/
